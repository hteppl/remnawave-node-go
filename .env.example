# The SECRET_KEY generated and provided by the Remnawave panel.
SECRET_KEY=

# Optional: Port for the main HTTPS server (default: 2222)
NODE_PORT=2222

# Optional: Port for the internal HTTP server, localhost only (default: 61001)
INTERNAL_REST_PORT=61001

# Optional: Log level — debug, info, warn, error (default: info)
LOG_LEVEL=info
